@startuml
title IPC Network Monitor - Component Diagram

skinparam componentStyle rectangle
skinparam shadowing false

package "Userspace" {
  [kernel-spy] as kernel_spy
  [collector] as collector
  [ui] as ui
  [ops / admin ctl client] as ctl_client
}

package "Shared Libraries" {
  [common] as common
  [kernel-spy-common] as kernel_spy_common
}

package "Kernel Space" {
  [kernel-spy-ebpf] as kernel_spy_ebpf
}

database "Unix socket\n/tmp/ipc-netmon.sock" as export_socket
database "Unix socket\n/tmp/ipc-netmon-ctl.sock" as control_socket

kernel_spy --> kernel_spy_ebpf : loads / attaches
kernel_spy --> kernel_spy_common : flow keys, counters
kernel_spy --> common : builds MonitorSnapshotV1
kernel_spy --> export_socket : write snapshots
export_socket --> collector : read snapshots
export_socket --> ui : read snapshots

kernel_spy --> control_socket : bind / receive requests
ctl_client --> control_socket : send JSON RPC request
control_socket --> ctl_client : send JSON RPC response
collector --> common : parse_export_line()
ui --> common : parse_export_line()

kernel_spy_ebpf --> kernel_spy_common : PacketMetadata / maps


@enduml