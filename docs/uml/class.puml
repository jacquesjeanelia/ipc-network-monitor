@startuml
title IPC Network Monitor - Shared Data Model

skinparam classAttributeIconSize 0
skinparam shadowing false

package "common" {
  class DirectionTotals {
    +packets: u64
    +bytes: u64
  }

  class FlowRow {
    +src_ip: String
    +dst_ip: String
    +src_port: u16
    +dst_port: u16
    +protocol: String
    +bytes: u64
    +local_pid: Option<u32>
    +local_uid: Option<u32>
    +local_username: Option<String>
  }

  class HealthSnapshot {
    +tcp_retransmit_skb: u64
    +policy_drops: u64
    +netdev_rx_dropped: Option<u64>
    +netdev_tx_dropped: Option<u64>
  }

  class ProbeStatus {
    +xdp_attached: bool
    +tc_egress_attached: bool
    +tcp_retransmit_trace_attached: bool
    +cgroup_pid_hooks_attached: bool
    +nftables_ready: bool
    +errors: Vec<String>
  }

  class SessionInfo {
    +session_id: String
    +window_start_ms: u64
  }

  class ProcessTrafficRow {
    +pid: u32
    +comm: Option<String>
    +bytes_total: u64
  }

  class UserTrafficRow {
    +uid: u32
    +username: Option<String>
    +bytes_total: u64
  }

  class AlertEvent {
    +ts_unix_ms: u64
    +kind: String
    +message: String
    +severity: String
  }

  class MonitorSnapshotV1 {
    +schema_version: u32
    +ts_unix_ms: u64
    +iface: String
    +rx: DirectionTotals
    +tx: DirectionTotals
    +health: HealthSnapshot
    +flows_rx: Vec<FlowRow>
    +flows_tx: Vec<FlowRow>
    +probe_status: ProbeStatus
    +session: SessionInfo
    +aggregates_by_pid: Vec<ProcessTrafficRow>
    +aggregates_by_user: Vec<UserTrafficRow>
    +alerts: Vec<AlertEvent>
  }

  enum ExportLine {
    MonitorSnapshot
  }

  class ControlAuditEntry {
    +ts_unix_ms: u64
    +action: String
    +detail: String
    +outcome: Option<String>
    +session_id: Option<String>
  }
}

package "kernel-spy-common" {
  class PacketMetadata {
    +src_ip: u32
    +dst_ip: u32
    +src_port: u16
    +dst_port: u16
    +protocol: u8
  }

  class PacketMetadataV6 {
    +src_ip: [u8;16]
    +dst_ip: [u8;16]
    +src_port: u16
    +dst_port: u16
    +protocol: u8
  }

  class BlocklistIpv6Key {
    +addr: [u8;16]
  }

  enum HealthCounterIndex {
    TcpRetransmitSkb
    PolicyDrop
  }

  class FlowMapCapacity
}

MonitorSnapshotV1 *-- DirectionTotals
MonitorSnapshotV1 *-- HealthSnapshot
MonitorSnapshotV1 *-- ProbeStatus
MonitorSnapshotV1 *-- SessionInfo
MonitorSnapshotV1 *-- ProcessTrafficRow
MonitorSnapshotV1 *-- UserTrafficRow
MonitorSnapshotV1 *-- AlertEvent
MonitorSnapshotV1 o-- FlowRow
ExportLine ..> MonitorSnapshotV1 : wraps
PacketMetadata ..> HealthCounterIndex
PacketMetadataV6 ..> HealthCounterIndex

@enduml